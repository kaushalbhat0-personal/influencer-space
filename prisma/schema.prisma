generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

model Tenant {
  id                    String    @id @default(uuid()) @db.Uuid
  name                  String
  subdomain             String    @unique
  customDomain          String?
  razorpayAccountId     String?   @unique
  razorpaySetupComplete Boolean   @default(false)
  youtubeChannelId      String?
  twitchChannelId       String?
  youtubeApiKey         String?
  instagramApiKey       String?
  instagramAccessToken  String?   @db.Text
  instagramRefreshToken String?   @db.Text
  instagramTokenExpiry  DateTime?
  twitchAccessToken     String?   @db.Text
  twitchRefreshToken    String?   @db.Text
  twitchTokenExpiry     DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  users              User[]
  products           Product[]
  affiliateLinks     AffiliateLink[]
  galleryImages      GalleryImage[]
  timelineEvents     TimelineEvent[]
  games              Game[]
  settings           Setting[]
  contactSubmissions ContactSubmission[]
  subscription       Subscription?
  productOrders      ProductOrder[]
  socialStats        SocialStats[]
  auditLogs          AuditLog[]
  contentFeedItems   ContentFeedItem[]
}

model Subscription {
  id                      String    @id @default(uuid()) @db.Uuid
  tenantId                String    @unique @db.Uuid
  razorpaySubscriptionId  String?
  status                  String    @default("FREE")
  plan                    String    @default("STARTER")
  currentPeriodEnd        DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @db.Uuid
  name      String?
  email     String
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  description String?
  price       Float
  imageUrl    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders ProductOrder[]

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ProductOrder {
  id                String   @id @default(cuid())
  tenantId          String   @db.Uuid
  productId         String   @db.Uuid
  amount            Float
  status            String   @default("PENDING")
  razorpayOrderId   String   @unique
  razorpayPaymentId String?
  fanEmail          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
}

model AffiliateLink {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  title     String
  url       String
  imageUrl  String?
  order     Int      @default(0)
  clicks    Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ContactSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Setting {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}

model GalleryImage {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  title       String
  description String?
  imageUrl    String
  mediaType   String   @default("image")
  videoUrl    String?
  category    String   @default("bgmi")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TimelineEvent {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  year        String
  title       String
  description String
  imageUrl    String?
  stats       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Game {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  logoUrl     String?
  description String?
  genre       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SocialStats {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  platform  String
  followers Int      @default(0)
  views     Int      @default(0)
  posts     Int      @default(0)
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, platform])
  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  action    String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model ContentFeedItem {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  platform     String   // "instagram" | "twitch" | "youtube"
  mediaType    String   // "image" | "video"
  url          String   @db.Text
  thumbnailUrl String?  @db.Text
  caption      String?  @db.Text
  permalink    String?  @db.Text
  pinned       Boolean  @default(false)
  hidden       Boolean  @default(false)
  externalId   String?  // platform's native post ID (dedup key)
  order        Int      @default(0)
  syncedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalId])
  @@index([tenantId, pinned, hidden, order])
}
