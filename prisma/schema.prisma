generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  AGENCY_ADMIN
  AGENCY_STAFF
  ADMIN
}

enum AgencyStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  EXPIRED
}

model Tenant {
  id                    String    @id @default(uuid()) @db.Uuid
  name                  String
  subdomain             String    @unique
  customDomain          String?
  razorpayAccountId     String?   @unique
  razorpaySetupComplete Boolean   @default(false)
  youtubeChannelId      String?
  twitchChannelId       String?
  youtubeApiKey         String?
  instagramApiKey       String?
  instagramAccessToken  String?   @db.Text
  instagramRefreshToken String?   @db.Text
  instagramTokenExpiry  DateTime?
  twitchAccessToken     String?   @db.Text
  twitchRefreshToken    String?   @db.Text
  twitchTokenExpiry     DateTime?
  themeId               String?   @db.Uuid
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  theme              Theme?  @relation(fields: [themeId], references: [id])
  agencyTenant       AgencyTenant?
  users              User[]
  products           Product[]
  affiliateLinks     AffiliateLink[]
  galleryImages      GalleryImage[]
  timelineEvents     TimelineEvent[]
  games              Game[]
  settings           Setting[]
  contactSubmissions ContactSubmission[]
  subscription       Subscription?
  productOrders      ProductOrder[]
  socialStats        SocialStats[]
  auditLogs          AuditLog[]
  contentFeedItems   ContentFeedItem[]
}

model Theme {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @unique
  primaryColor    String   @default("#2D1B69")
  secondaryColor  String   @default("#00f5ff")
  accentColor     String   @default("#ff00e5")
  backgroundColor String   @default("#09090b")
  textColor       String   @default("#ffffff")
  fontFamily      String   @default("Inter")
  borderRadius    String   @default("8px")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenants        Tenant[]
  agencyDefaults WebsiteAgency[]   @relation("DefaultTheme")
}

model Subscription {
  id                      String    @id @default(uuid()) @db.Uuid
  tenantId                String    @unique @db.Uuid
  razorpaySubscriptionId  String?
  status                  String    @default("FREE")
  plan                    String    @default("STARTER")
  currentPeriodEnd        DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model WebsiteAgency {
  id                    String        @id @default(uuid()) @db.Uuid
  name                  String
  subdomain             String        @unique
  customDomain          String?
  razorpayAccountId     String?       @unique
  razorpaySetupComplete Boolean       @default(false)
  defaultThemeId        String?       @db.Uuid
  platformFeePercent    Float         @default(0)
  status                AgencyStatus  @default(TRIAL)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  defaultTheme Theme?              @relation("DefaultTheme", fields: [defaultThemeId], references: [id])
  users        User[]
  tenants      AgencyTenant[]
  subscription AgencySubscription?
}

model AgencyTenant {
  id                     String   @id @default(uuid()) @db.Uuid
  agencyId               String   @db.Uuid
  tenantId               String   @db.Uuid  @unique
  revSharePercent        Float    @default(20)
  productRevSharePercent Float    @default(10)
  canEditTheme           Boolean  @default(true)
  canEditProducts        Boolean  @default(true)
  canEditGallery         Boolean  @default(true)
  canEditLinks           Boolean  @default(true)
  canEditMilestones      Boolean  @default(true)
  canEditSettings        Boolean  @default(false)
  status                 String   @default("ACTIVE")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  agency WebsiteAgency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([agencyId])
}

model AgencySubscription {
  id                      String    @id @default(uuid()) @db.Uuid
  agencyId                String    @unique @db.Uuid
  razorpaySubscriptionId  String?
  status                  String    @default("FREE")
  plan                    String    @default("STARTER")
  maxManagedTenants       Int       @default(3)
  currentPeriodEnd        DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  agency WebsiteAgency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @db.Uuid
  agencyId  String?  @db.Uuid
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agency WebsiteAgency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([agencyId])
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  description String?
  price       Float
  imageUrl    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders ProductOrder[]

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ProductOrder {
  id                String   @id @default(cuid())
  tenantId          String   @db.Uuid
  productId         String   @db.Uuid
  amount            Float
  status            String   @default("PENDING")
  razorpayOrderId   String   @unique
  razorpayPaymentId String?
  fanEmail          String?
  platformFeePercent Float  @default(5)
  agencyFeePercent   Float?
  agencyId           String?  @db.Uuid
  routeTransferId    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
}

model AffiliateLink {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  title     String
  url       String
  imageUrl  String?
  order     Int      @default(0)
  clicks    Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ContactSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Setting {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}

model GalleryImage {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  title       String
  description String?
  imageUrl    String
  mediaType   String   @default("image")
  videoUrl    String?
  category    String   @default("bgmi")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TimelineEvent {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  year        String
  title       String
  description String
  imageUrl    String?
  stats       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Game {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  logoUrl     String?
  description String?
  genre       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SocialStats {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  platform  String
  followers Int      @default(0)
  views     Int      @default(0)
  posts     Int      @default(0)
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, platform])
  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  action    String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model ContentFeedItem {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  platform     String   // "instagram" | "twitch" | "youtube"
  mediaType    String   // "image" | "video"
  url          String   @db.Text
  thumbnailUrl String?  @db.Text
  caption      String?  @db.Text
  permalink    String?  @db.Text
  pinned       Boolean  @default(false)
  hidden       Boolean  @default(false)
  externalId   String?  // platform's native post ID (dedup key)
  order        Int      @default(0)
  syncedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalId])
  @@index([tenantId, pinned, hidden, order])
}
