generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  AGENCY_ADMIN
  AGENCY_STAFF
  ADMIN
}

enum AgencyStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  EXPIRED
}

model Tenant {
  id                    String    @id @default(uuid()) @db.Uuid
  name                  String
  subdomain             String    @unique
  customDomain          String?
  razorpayAccountId     String?   @unique
  razorpaySetupComplete Boolean   @default(false)
  youtubeChannelId      String?
  twitchChannelId       String?
  youtubeApiKey         String?
  instagramApiKey       String?
  instagramAccessToken  String?   @db.Text
  instagramRefreshToken String?   @db.Text
  instagramTokenExpiry  DateTime?
  twitchAccessToken     String?   @db.Text
  twitchRefreshToken    String?   @db.Text
  twitchTokenExpiry     DateTime?
  themeId               String?   @db.Uuid
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  theme              Theme?  @relation(fields: [themeId], references: [id])
  agencyTenant       AgencyTenant?
  users              User[]
  products           Product[]
  affiliateLinks     AffiliateLink[]
  galleryImages      GalleryImage[]
  timelineEvents     TimelineEvent[]
  games              Game[]
  settings           Setting[]
  contactSubmissions ContactSubmission[]
  subscription       Subscription?
  productOrders      ProductOrder[]
  socialStats        SocialStats[]
  auditLogs          AuditLog[]
  contentFeedItems   ContentFeedItem[]
  website            Website?
}

/// One Website per Tenant — the aggregate root for storefront content.
/// Replaces the implicit website stored across Setting rows.
model Website {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @unique @db.Uuid
  themePackageId   String        @default("neon-dark")
  themeColors      Json          @default("{}")
  themeFonts       Json          @default("{}")
  themeConfig      Json          @default("{}")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand            Brand?
  publishStatus    PublishStatus?
  pages            Page[]

  @@index([tenantId])
}

/// Brand identity — replaces brand_config + influencer_data settings.
model Brand {
  id          String   @id @default(uuid()) @db.Uuid
  websiteId   String   @unique @db.Uuid
  name        String
  tagline     String   @default("")
  bio         String   @default("")
  avatarUrl   String?
  bannerUrl   String?
  socialLinks Json     @default("[]")

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

/// Publish lifecycle — replaces demo_metadata setting.
model PublishStatus {
  id          String    @id @default(uuid()) @db.Uuid
  websiteId   String    @unique @db.Uuid
  state       String    @default("draft")  // "draft" | "preview" | "live" | "archived"
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Theme {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @unique
  primaryColor    String   @default("#2D1B69")
  secondaryColor  String   @default("#00f5ff")
  accentColor     String   @default("#ff00e5")
  backgroundColor String   @default("#09090b")
  textColor       String   @default("#ffffff")
  fontFamily      String   @default("Inter")
  borderRadius    String   @default("8px")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenants        Tenant[]
  agencyDefaults WebsiteAgency[]   @relation("DefaultTheme")
}

model Subscription {
  id                      String    @id @default(uuid()) @db.Uuid
  tenantId                String    @unique @db.Uuid
  razorpaySubscriptionId  String?
  status                  String    @default("FREE")
  plan                    String    @default("STARTER")
  currentPeriodEnd        DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model WebsiteAgency {
  id                    String        @id @default(uuid()) @db.Uuid
  name                  String
  subdomain             String        @unique
  customDomain          String?
  razorpayAccountId     String?       @unique
  razorpaySetupComplete Boolean       @default(false)
  defaultThemeId        String?       @db.Uuid
  platformFeePercent    Float         @default(0)
  status                AgencyStatus  @default(TRIAL)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  defaultTheme Theme?              @relation("DefaultTheme", fields: [defaultThemeId], references: [id])
  users        User[]
  tenants      AgencyTenant[]
  subscription AgencySubscription?
}

model AgencyTenant {
  id                     String   @id @default(uuid()) @db.Uuid
  agencyId               String   @db.Uuid
  tenantId               String   @db.Uuid  @unique
  revSharePercent        Float    @default(20)
  productRevSharePercent Float    @default(10)
  canEditTheme           Boolean  @default(true)
  canEditProducts        Boolean  @default(true)
  canEditGallery         Boolean  @default(true)
  canEditLinks           Boolean  @default(true)
  canEditMilestones      Boolean  @default(true)
  canEditSettings        Boolean  @default(false)
  status                 String   @default("ACTIVE")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  agency WebsiteAgency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([agencyId])
}

model AgencySubscription {
  id                      String    @id @default(uuid()) @db.Uuid
  agencyId                String    @unique @db.Uuid
  razorpaySubscriptionId  String?
  status                  String    @default("FREE")
  plan                    String    @default("STARTER")
  maxManagedTenants       Int       @default(3)
  currentPeriodEnd        DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  agency WebsiteAgency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @db.Uuid
  agencyId  String?  @db.Uuid
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agency WebsiteAgency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([agencyId])
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  description String?
  price       Float
  imageUrl    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders ProductOrder[]

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ProductOrder {
  id                String   @id @default(cuid())
  tenantId          String   @db.Uuid
  productId         String   @db.Uuid
  amount            Float
  status            String   @default("PENDING")
  razorpayOrderId   String   @unique
  razorpayPaymentId String?
  fanEmail          String?
  platformFeePercent Float  @default(5)
  agencyFeePercent   Float?
  agencyId           String?  @db.Uuid
  routeTransferId    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
}

model AffiliateLink {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  title     String
  url       String
  imageUrl  String?
  order     Int      @default(0)
  clicks    Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ContactSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Setting {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}

model GalleryImage {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  title       String
  description String?
  imageUrl    String
  mediaType   String   @default("image")
  videoUrl    String?
  category    String   @default("bgmi")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TimelineEvent {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  year        String
  title       String
  description String
  imageUrl    String?
  stats       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Game {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  logoUrl     String?
  description String?
  genre       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SocialStats {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  platform  String
  followers Int      @default(0)
  views     Int      @default(0)
  posts     Int      @default(0)
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, platform])
  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  action    String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model ContentFeedItem {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  platform     String   // "instagram" | "twitch" | "youtube"
  mediaType    String   // "image" | "video"
  url          String   @db.Text
  thumbnailUrl String?  @db.Text
  caption      String?  @db.Text
  permalink    String?  @db.Text
  pinned       Boolean  @default(false)
  hidden       Boolean  @default(false)
  externalId   String?  // platform's native post ID (dedup key)
  order        Int      @default(0)
  syncedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalId])
  @@index([tenantId, pinned, hidden, order])
}

// ──────────────────────────────────────────────────────────────────────────────
// Builder — Pages, Sections, Blocks (persisted workspace state)
// ──────────────────────────────────────────────────────────────────────────────

/// A page within a website's builder workspace.
model Page {
  id        String   @id @default(uuid()) @db.Uuid
  websiteId String   @db.Uuid
  name      String
  slug      String
  order     Int      @default(0)
  isHome    Boolean  @default(false)
  theme     String   @default("default")
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  website  Website   @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  sections Section[]

  @@unique([websiteId, slug])
  @@index([websiteId])
}

/// A section within a page — holds blocks.
model Section {
  id        String   @id @default(uuid()) @db.Uuid
  pageId    String   @db.Uuid
  name      String
  order     Int      @default(0)
  visible   Boolean  @default(true)
  locked    Boolean  @default(false)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page   Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  blocks Block[]

  @@index([pageId])
}

/// A content block within a section — the atomic unit a creator edits.
model Block {
  id        String   @id @default(uuid()) @db.Uuid
  sectionId String   @db.Uuid
  moduleId  String
  parentId  String?
  order     Int      @default(0)
  visible   Boolean  @default(true)
  locked    Boolean  @default(false)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Creator Provisioning — State Machine + Event Log
// ──────────────────────────────────────────────────────────────────────────────

/// One row per provisioning run — tracks overall status and current step.
model CreatorProvisionRun {
  id              String   @id @default(uuid()) @db.Uuid
  creatorName     String
  sourceUrl       String?
  sourcePlatform  String?
  tenantId        String?  @db.Uuid
  tenantSlug      String?
  status          String   @default("PENDING")
  currentStep     String   @default("IMPORT_REQUESTED")
  error           String?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  durationMs      Int?
  metadata        Json     @default("{}")

  events CreatorProvisionEvent[]

  @@index([status])
  @@index([startedAt])
  @@index([tenantId])
}

/// Append-only event log — every state transition is recorded here.
model CreatorProvisionEvent {
  id        String   @id @default(uuid()) @db.Uuid
  runId     String   @db.Uuid
  step      String
  event     String   // "started" | "completed" | "failed"
  message   String?
  timestamp DateTime @default(now())

  run CreatorProvisionRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, timestamp])
}

// ──────────────────────────────────────────────────────────────────────────────
// Billing v2 — Phase 1 Foundation (additive — legacy tables preserved)
// ──────────────────────────────────────────────────────────────────────────────

/// Billing account — single billable entity for creators and agencies.
/// Replaces the polymorphic subscription pattern.
model BillingAccount {
  id          String   @id @default(uuid()) @db.Uuid
  accountType String   // "tenant" | "agency"
  accountId   String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions BillingSubscription[]

  @@unique([accountType, accountId])
}

/// Immutable plan catalog entry.
/// Plans are versioned — never edited after customers subscribe.
model BillingPlan {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique // "creator_free", "creator_pro", "agency_starter", etc.
  family    String            // "creator" | "agency"
  name      String
  price     Float    @default(0)
  currency  String   @default("INR")
  cycle     String   @default("monthly") // "monthly" | "annual"
  status    String   @default("ACTIVE")  // "ACTIVE" | "DEPRECATED" | "GRANDFATHERED"
  version   Int      @default(1)
  createdAt DateTime @default(now())

  features   BillingPlanFeature[]
  subscriptions BillingSubscription[]
}

/// Typed feature definitions.
/// New features are added to this table, never edited.
model BillingFeature {
  id          String @id @default(uuid()) @db.Uuid
  key         String @unique // "max_products", "custom_domain", "max_clients", etc.
  description String
  valueType   String @default("integer") // "integer" | "boolean" | "string"

  planFeatures BillingPlanFeature[]
}

/// Join table with typed feature values.
/// JSON reserved for future complex configurations only.
model BillingPlanFeature {
  planId    String @db.Uuid
  featureId String @db.Uuid
  intValue  Int?
  boolValue Boolean?
  strValue  String?

  plan    BillingPlan  @relation(fields: [planId], references: [id])
  feature BillingFeature @relation(fields: [featureId], references: [id])

  @@id([planId, featureId])
}

/// Unified subscription — one table for all billing.
/// Separation: Payment → Billing Event → Subscription State → Feature Gate
model BillingSubscription {
  id          String    @id @default(uuid()) @db.Uuid
  accountId   String    @db.Uuid
  planId      String    @db.Uuid
  status      String    @default("ACTIVE") // "TRIALING" | "ACTIVE" | "PAST_DUE" | "CANCELLED" | "EXPIRED"
  trialEndsAt DateTime?
  renewsAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  account BillingAccount @relation(fields: [accountId], references: [id])
  plan    BillingPlan    @relation(fields: [planId], references: [id])

  @@index([accountId])
  @@index([planId])
}

/// Immutable billing event log. Append-only, never edited.
/// Provides idempotency key for webhook processing.
model BillingEvent {
  id           String   @id @default(uuid()) @db.Uuid
  accountId    String   @db.Uuid
  type         String   // SUBSCRIPTION_CREATED, CHECKOUT_STARTED, PAYMENT_SUCCEEDED, PAYMENT_FAILED, SUBSCRIPTION_ACTIVATED, SUBSCRIPTION_RENEWED, SUBSCRIPTION_CANCELLED, REFUND_CREATED, REFUND_COMPLETED, INVOICE_ISSUED, INVOICE_PAID
  idempotencyKey String? @unique // Prevents duplicate webhook processing
  payload      Json?
  createdAt    DateTime @default(now())

  @@index([accountId])
  @@index([type])
  @@index([createdAt])
}

/// Financial source of truth. Immutable after payment.
/// Created before checkout, finalized after payment success.
model BillingInvoice {
  id               String    @id @default(uuid()) @db.Uuid
  accountId        String    @db.Uuid
  subscriptionId   String?   @db.Uuid
  planCode         String    // Plan code at time of invoice (grandfathering)
  planVersion      Int       @default(1)
  amount           Float
  currency         String    @default("INR")
  status           String    @default("PENDING") // PENDING, PAID, FAILED, REFUNDED, VOID
  provider         String?   // "razorpay" | "stripe" | "manual"
  providerReference String?  // Razorpay order_id / Stripe payment_intent_id
  issuedAt         DateTime  @default(now())
  paidAt           DateTime?
  metadata         Json?
  createdAt        DateTime  @default(now())

  @@index([accountId])
  @@index([status])
}
