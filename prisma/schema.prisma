generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

model Tenant {
  id                    String    @id @default(uuid()) @db.Uuid
  name                  String
  subdomain             String    @unique
  customDomain          String?
  razorpayAccountId     String?   @unique
  razorpaySetupComplete Boolean   @default(false)
  youtubeChannelId      String?
  twitchChannelId       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  users              User[]
  products           Product[]
  affiliateLinks     AffiliateLink[]
  galleryImages      GalleryImage[]
  timelineEvents     TimelineEvent[]
  games              Game[]
  settings           Setting[]
  contactSubmissions ContactSubmission[]
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @db.Uuid
  name      String?
  email     String
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  description String?
  price       Float
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model AffiliateLink {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  title     String
  url       String
  imageUrl  String?
  clicks    Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ContactSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Setting {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}

model GalleryImage {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  title       String
  description String?
  imageUrl    String
  category    String   @default("bgmi")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TimelineEvent {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  year        String
  title       String
  description String
  imageUrl    String?
  stats       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Game {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  logoUrl     String?
  description String?
  genre       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}
