# Runtime — PgBouncer (port 6543, pooled connections for serverless)
DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true&sslmode=require"

# Migrations — Direct connection (port 5432, required by prisma migrate/db push)
DIRECT_URL="postgresql://[USER]:[PASSWORD]@[HOST]:5432/postgres?sslmode=require"

NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"
HEALTH_SECRET="your-random-health-secret"
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
INSTAGRAM_ACCESS_TOKEN="your-instagram-access-token"
YOUTUBE_API_KEY="your-youtube-api-key"
