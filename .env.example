# ============================================================================
# CreatorStore — Environment Variables
# Copy to .env.local and fill in your real values.
# Run `node scripts/validate-env.mjs` to verify before deployment.
# ============================================================================

# ─── Database ───────────────────────────────────────────────────────────────
# Pooled connection (PgBouncer, port 6543) — used at runtime by Prisma
DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true&sslmode=require"
# Direct connection (port 5432) — required by prisma migrate / db push
DIRECT_URL="postgresql://[USER]:[PASSWORD]@[HOST]:5432/postgres?sslmode=require"

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://influencer-space-alpha.vercel.app"
NEXTAUTH_URL="https://influencer-space-alpha.vercel.app"
NEXTAUTH_SECRET="your-random-secret-here"          # openssl rand -base64 32
DEFAULT_TENANT_SUBDOMAIN="snax"                     # fallback tenant host

# ─── Security ───────────────────────────────────────────────────────────────
CRON_SECRET="your-random-cron-secret"              # openssl rand -base64 32
TOKEN_ENCRYPTION_KEY="your-64-char-hex-key"        # openssl rand -hex 32
HEALTH_SECRET="your-random-health-secret"          # openssl rand -base64 32

# ─── Supabase (Storage + DB) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ─── Payments ───────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"   # optional (future)

# ─── Social APIs (Platform-level fallback keys) ─────────────────────────────
YOUTUBE_API_KEY="your-youtube-api-key"
INSTAGRAM_ACCESS_TOKEN="your-instagram-access-token"
TWITCH_CLIENT_ID="your-twitch-client-id"
TWITCH_CLIENT_SECRET="your-twitch-client-secret"

# ─── Vercel (Custom Domain Provisioning) ────────────────────────────────────
VERCEL_API_TOKEN="your-vercel-api-token"           # Generate in Vercel Dashboard → Settings → Tokens
VERCEL_PROJECT_ID="prj_xxxxxxxxxxxxxxxxxxxx"       # From Vercel Dashboard → Project Settings
